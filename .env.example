# Copy this file to .env and adjust values before running docker compose.
# .env is gitignored — safe to put credentials here for local development.

# ── Local data directory ──────────────────────────────────────────────────────
# Host path mounted to /data inside the ZeaOS container.
# Drop your Parquet, CSV, or JSON files here and load them with:
#   ZeaOS> t = load /data/myfile.parquet
#
# ZEA_DATA_DIR=/Users/you/datasets

# ── MinIO (docker-compose local instance) ────────────────────────────────────
# These match the docker-compose defaults. Change them if you're running MinIO
# with non-default credentials.
#
# MINIO_USER=minioadmin
# MINIO_PASSWORD=minioadmin
# ZEA_S3_BUCKET=zeaos-data

# ── Existing MinIO cluster ───────────────────────────────────────────────────
# To connect to an existing MinIO instance instead of the local one, override
# the endpoint and credentials, then skip starting the minio service:
#   docker compose run --rm zeaos
#
# ZEA_TEST_S3_ENDPOINT=https://minio.yourorg.com
# ZEA_TEST_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ── MotherDuck ────────────────────────────────────────────────────────────────
# Required for: push --target md:database
#
# MOTHERDUCK_TOKEN=your-token-here
